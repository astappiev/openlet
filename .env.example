# Openlet - Environment Variables

# Public site origin (no trailing slash). Used for canonical URLs, Open Graph,
# and Google Organization logo structured data. Example: https://openlet.app
VITE_SITE_URL=https://your-domain.example

# Postgres connection (Supabase or any Postgres-compatible host).
# Use a pooler connection (port 6543) for serverless deployments.
# Example: postgresql://user:password@host:5432/postgres
DATABASE_URL=

# Supabase Auth - required for authentication
# Get these from your Supabase project dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth is configured in Supabase dashboard > Authentication > Providers > Google
# No additional environment variables required for OAuth flow.

# Optional: "development" or "production"
NODE_ENV=development
