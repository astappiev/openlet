{
  "name": "openlet",
  "version": "0.1.0",
  "private": false,
  "description": "Free, open-source flashcard app with spaced repetition. Quizlet product feel without the paywall.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChloeVPin/openlet"
  },
  "keywords": [
    "flashcards",
    "study",
    "spaced-repetition",
    "fsrs",
    "quizlet",
    "education",
    "open-source",
    "tanstack",
    "react"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
