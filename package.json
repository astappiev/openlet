    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
