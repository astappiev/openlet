    "@tanstack/react-start": "^1.168.27",
    "@tanstack/router-plugin": "^1.168.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "postgres": "^3.4.9",
    "react": "^19",
